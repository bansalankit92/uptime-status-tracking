{
  "name": "uptime-monitor",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:tailwind\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "cd client && npx vite",
    "dev:tailwind": "npx @tailwindcss/cli -i ./styles/input.css -o ./public/css/tailwind.css --watch",
    "build:client": "cd client && npx vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:tailwind": "npx @tailwindcss/cli -i ./styles/input.css -o ./public/css/tailwind.css --minify",
    "build": "npm run build:tailwind && npm run build:client && npm run build:server",
    "start": "node dist/server/src/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx server/src/db/migrate.ts",
    "db:seed": "tsx server/src/db/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.1",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.15.0",
    "@types/nodemailer": "^7.0.11",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
}
