<!DOCTYPE html>
<html lang="en" <% if (page.colorMode === 'dark') { %>class="dark"<% } %>>
<head>
  <%- include('../../partials/head', { page }) %>
</head>
<body class="font-<%= page.fontFamily %> min-h-screen
  <%= page.colorMode === 'dark' ? 'bg-gray-950 text-gray-100' : 'bg-gray-50 text-gray-900' %>">

  <!-- Hero Banner -->
  <div class="<%= page.colorMode === 'dark' ? 'bg-gray-900' : 'bg-white' %> border-b <%= page.colorMode === 'dark' ? 'border-gray-800' : 'border-gray-200' %>">
    <div class="max-w-4xl mx-auto px-6 py-10">
      <div class="flex items-center gap-4 mb-4">
        <% if (page.logoUrl) { %>
          <img src="<%= page.logoUrl %>" alt="Logo" class="h-10">
        <% } %>
        <h1 class="text-3xl font-bold"><%= page.headerText || page.title %></h1>
      </div>
      <% if (page.description) { %>
        <p class="<%= page.colorMode === 'dark' ? 'text-gray-400' : 'text-gray-600' %> text-lg"><%= page.description %></p>
      <% } %>

      <!-- Overall Status Badge -->
      <div class="mt-6 inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium
        <%= page.overallStatus === 'up' ? 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300' :
           page.overallStatus === 'down' ? 'bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300' :
           page.overallStatus === 'degraded' ? 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/40 dark:text-yellow-300' :
           'bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400' %>">
        <div class="w-2.5 h-2.5 rounded-full animate-pulse" style="background-color: <%= helpers.statusColor(page.overallStatus) %>"></div>
        <%= helpers.statusLabel(page.overallStatus) %>
      </div>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-6 py-8">

    <!-- Monitor Cards -->
    <div class="grid gap-4">
      <% for (const monitor of page.monitors) { %>
        <div class="<%= page.colorMode === 'dark' ? 'bg-gray-900 border-gray-800' : 'bg-white border-gray-200' %> border rounded-xl p-5 shadow-sm">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-3">
              <div class="w-3 h-3 rounded-full" style="background-color: <%= helpers.statusColor(monitor.status) %>"></div>
              <span class="font-semibold"><%= monitor.name %></span>
            </div>
            <div class="flex items-center gap-4">
              <% if (monitor.responseTimeMs) { %>
                <span class="text-xs <%= page.colorMode === 'dark' ? 'text-gray-500' : 'text-gray-400' %>"><%= Math.round(monitor.responseTimeMs) %>ms</span>
              <% } %>
              <span class="text-sm font-medium" style="color: <%= helpers.statusColor(monitor.status) %>"><%= helpers.formatUptime(monitor.uptimePercentage) %></span>
            </div>
          </div>
          <%- include('../../partials/uptime-bar', { monitor, page, helpers }) %>
          <div class="flex justify-between mt-1.5">
            <span class="text-xs <%= page.colorMode === 'dark' ? 'text-gray-600' : 'text-gray-400' %>"><%= page.uptimeDaysToShow %>d ago</span>
            <span class="text-xs <%= page.colorMode === 'dark' ? 'text-gray-600' : 'text-gray-400' %>">Now</span>
          </div>
        </div>
      <% } %>
    </div>

    <!-- Incidents -->
    <%- include('../../partials/incidents', { page, helpers }) %>

    <!-- Footer -->
    <%- include('../../partials/footer', { page }) %>
  </div>

</body>
</html>
