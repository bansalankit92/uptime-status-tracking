<!DOCTYPE html>
<html lang="en" <% if (page.colorMode === 'dark') { %>class="dark"<% } %>>
<head>
  <%- include('../../partials/head', { page }) %>
</head>
<body class="font-<%= page.fontFamily %> min-h-screen
  <%= page.colorMode === 'dark' ? 'bg-gray-950 text-gray-100' : 'bg-white text-gray-900' %>">

  <div class="max-w-3xl mx-auto px-4 py-12">

    <!-- Header -->
    <header class="mb-10">
      <% if (page.logoUrl) { %>
        <img src="<%= page.logoUrl %>" alt="Logo" class="h-8 mb-4">
      <% } %>
      <h1 class="text-2xl font-semibold"><%= page.headerText || page.title %></h1>
      <% if (page.description) { %>
        <p class="mt-1 text-sm <%= page.colorMode === 'dark' ? 'text-gray-400' : 'text-gray-500' %>"><%= page.description %></p>
      <% } %>
    </header>

    <!-- Overall Status -->
    <div class="rounded-lg p-4 mb-8
      <%= page.overallStatus === 'up' ? 'bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800' :
         page.overallStatus === 'down' ? 'bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800' :
         page.overallStatus === 'degraded' ? 'bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800' :
         'bg-gray-50 dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700' %>">
      <div class="flex items-center gap-3">
        <div class="w-3 h-3 rounded-full" style="background-color: <%= helpers.statusColor(page.overallStatus) %>"></div>
        <span class="font-medium">
          <%= page.overallStatus === 'up' ? 'All Systems Operational' :
             page.overallStatus === 'down' ? 'System Outage Detected' :
             page.overallStatus === 'degraded' ? 'Partial System Degradation' :
             'Checking Systems...' %>
        </span>
      </div>
    </div>

    <!-- Monitors -->
    <div class="space-y-6">
      <% for (const monitor of page.monitors) { %>
        <div>
          <div class="flex items-center justify-between mb-2">
            <div class="flex items-center gap-2">
              <span class="font-medium text-sm"><%= monitor.name %></span>
              <span class="inline-block w-2 h-2 rounded-full" style="background-color: <%= helpers.statusColor(monitor.status) %>"></span>
            </div>
            <span class="text-xs <%= page.colorMode === 'dark' ? 'text-gray-400' : 'text-gray-500' %>">
              <%= helpers.formatUptime(monitor.uptimePercentage) %>
            </span>
          </div>
          <%- include('../../partials/uptime-bar', { monitor, page, helpers }) %>
          <div class="flex justify-between mt-1">
            <span class="text-xs <%= page.colorMode === 'dark' ? 'text-gray-500' : 'text-gray-400' %>"><%= page.uptimeDaysToShow %> days ago</span>
            <span class="text-xs <%= page.colorMode === 'dark' ? 'text-gray-500' : 'text-gray-400' %>">Today</span>
          </div>
        </div>
      <% } %>
    </div>

    <!-- Incidents -->
    <%- include('../../partials/incidents', { page, helpers }) %>

    <!-- Footer -->
    <%- include('../../partials/footer', { page }) %>
  </div>

</body>
</html>
